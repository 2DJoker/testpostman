{
  "info": {
    "_postman_id": "fd994f6d-706e-48c6-9d6c-b559cbf555d2",
    "name": "CRUD Books Tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Базовая коллекция для проверки CRUD-операций (Create, Read, Update, Delete) с автотестами."
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://jsonplaceholder.typicode.com",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. GET books by userId",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var responseJson = pm.response.json();",
              "",
              "pm.test(\"Status code is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response is a non-empty array\", function () {",
              "  pm.expect(Array.isArray(responseJson)).to.be.true;",
              "  pm.expect(responseJson.length).to.be.above(0);",
              "});",
              "",
              "pm.test(\"All records belong to selected userId\", function () {",
              "  var expectedUserId = Number(pm.environment.get(\"userId\"));",
              "  responseJson.forEach(item => pm.expect(item.userId).to.eql(expectedUserId));",
              "});",
              "",
              "pm.test(\"Response time is under 10000ms\", function () {",
              "  pm.expect(pm.response.responseTime).to.be.below(10000);",
              "});",
              "",
              "if (Array.isArray(responseJson) && responseJson.length > 0) {",
              "  pm.environment.set(\"postId\", responseJson[0].id);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/posts?userId={{userId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "posts"
          ],
          "query": [
            {
              "key": "userId",
              "value": "{{userId}}"
            }
          ]
        },
        "description": "Получить список записей для конкретного пользователя и сохранить postId первой записи."
      },
      "response": []
    },
    {
      "name": "2. POST create book",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var adjectives = [\"Hidden\", \"Lost\", \"Silent\", \"Golden\", \"Ancient\", \"Brave\"];",
              "var nouns = [\"Empire\", \"Forest\", \"River\", \"Legacy\", \"Chronicle\", \"Library\"];",
              "var randomPart = Math.floor(Math.random() * 100000);",
              "var title = `${adjectives[Math.floor(Math.random() * adjectives.length)]} ${nouns[Math.floor(Math.random() * nouns.length)]} #${randomPart}`;",
              "pm.environment.set(\"bookTitle\", title);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var responseJson = pm.response.json();",
              "",
              "pm.test(\"Status code is 201\", function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test(\"Created record contains id\", function () {",
              "  pm.expect(responseJson).to.have.property(\"id\");",
              "});",
              "",
              "pm.test(\"Title matches generated bookTitle\", function () {",
              "  pm.expect(responseJson.title).to.eql(pm.environment.get(\"bookTitle\"));",
              "});",
              "",
              "pm.test(\"Response time is under 10000ms\", function () {",
              "  pm.expect(pm.response.responseTime).to.be.below(10000);",
              "});",
              "",
              "if (responseJson && responseJson.id) {",
              "  pm.environment.set(\"createdId\", responseJson.id);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"{{bookTitle}}\",\n  \"body\": \"Autogenerated test payload for CRUD validation\",\n  \"userId\": {{userId}}\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/posts",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "posts"
          ]
        },
        "description": "Создать новую запись с рандомным названием книги из Pre-request Script."
      },
      "response": []
    },
    {
      "name": "3. GET book by postId",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var responseJson = pm.response.json();",
              "var expectedPostId = Number(pm.environment.get(\"postId\"));",
              "",
              "pm.test(\"Status code is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response id matches postId variable\", function () {",
              "  pm.expect(responseJson.id).to.eql(expectedPostId);",
              "});",
              "",
              "pm.test(\"Response has non-empty title\", function () {",
              "  pm.expect(responseJson.title).to.be.a(\"string\");",
              "  pm.expect(responseJson.title.length).to.be.above(0);",
              "});",
              "",
              "pm.test(\"Response time is under 10000ms\", function () {",
              "  pm.expect(pm.response.responseTime).to.be.below(10000);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/posts/{{postId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "posts",
            "{{postId}}"
          ]
        },
        "description": "Прочитать запись по ранее сохранённому postId."
      },
      "response": []
    },
    {
      "name": "4. PUT update book by postId",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var responseJson = pm.response.json();",
              "var expectedPostId = Number(pm.environment.get(\"postId\"));",
              "var expectedUserId = Number(pm.environment.get(\"userId\"));",
              "",
              "pm.test(\"Status code is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Updated record id matches postId\", function () {",
              "  pm.expect(responseJson.id).to.eql(expectedPostId);",
              "});",
              "",
              "pm.test(\"Updated title includes '(updated)'\", function () {",
              "  pm.expect(responseJson.title).to.include(\"(updated)\");",
              "});",
              "",
              "pm.test(\"Response userId matches environment userId\", function () {",
              "  pm.expect(Number(responseJson.userId)).to.eql(expectedUserId);",
              "});",
              "",
              "pm.test(\"Response time is under 10000ms\", function () {",
              "  pm.expect(pm.response.responseTime).to.be.below(10000);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"id\": {{postId}},\n  \"title\": \"{{bookTitle}} (updated)\",\n  \"body\": \"Updated payload from automated Postman test\",\n  \"userId\": {{userId}}\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/posts/{{postId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "posts",
            "{{postId}}"
          ]
        },
        "description": "Обновить запись по postId, используя bookTitle из POST."
      },
      "response": []
    },
    {
      "name": "5. DELETE book by postId",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200 or 204\", function () {",
              "  pm.expect([200, 204]).to.include(pm.response.code);",
              "});",
              "",
              "pm.test(\"Response body is empty object or empty string\", function () {",
              "  var text = pm.response.text().trim();",
              "  pm.expect(text === \"\" || text === \"{}\").to.be.true;",
              "});",
              "",
              "pm.test(\"Response time is under 10000ms\", function () {",
              "  pm.expect(pm.response.responseTime).to.be.below(10000);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/posts/{{postId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "posts",
            "{{postId}}"
          ]
        },
        "description": "Удалить запись по postId."
      },
      "response": []
    }
  ]
}
